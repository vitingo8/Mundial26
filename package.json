{
  "name": "porra-mundial-2026",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "npm run build:knockout",
    "dev": "next dev",
    "prebuild": "npm run build:knockout",
    "build": "next build",
    "postinstall": "npm run build:knockout",
    "start": "next start",
    "build:fifa-catalog": "node scripts/build-group-stage-catalog.mjs",
    "build:third-place-map": "node scripts/build-third-place-map.mjs data/fifa-2026-third-place-combinations.txt",
    "build:knockout": "tsc -p lib/knockout/tsconfig.build.json",
    "test": "npm run build:knockout && node --test lib/knockout/knockout.test.mjs",
    "test:all": "npm run build:knockout && node --test lib/gameData.test.mjs lib/bonusPlayerMatch.test.mjs lib/groupActuals.test.mjs lib/groupStandings.test.mjs lib/madridTime.test.mjs lib/fifaMatchNumbers.test.mjs lib/knockoutSchedule.official.test.mjs lib/matchSyncWindow.test.mjs lib/testScoringFixture.test.mjs lib/matchPointsDisplay.test.mjs && npm test",
    "sync:wc": "node scripts/sync-wc-github.mjs",
    "seed:test-scoring": "node --env-file=.env.local scripts/seed-test-scoring.mjs"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "typescript": "5.8.3"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@supabase/supabase-js": "^2.43.4",
    "@vercel/analytics": "^2.0.1",
    "lucide-react": "^1.17.0",
    "next": "14.2.5",
    "react": "^18",
    "react-dom": "^18"
  }
}
